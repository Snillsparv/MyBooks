{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksConfigPath": "podcast-summarizer/nixpacks.toml"
  },
  "deploy": {
    "startCommand": "cd podcast-summarizer && gunicorn app:app --bind 0.0.0.0:${PORT:-5000}",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
